{
  "functions": {
    "api/blog/[slug].ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "Googlebot|Yeti|Baiduspider|bingbot|DuckDuckBot|facebookexternalhit|Twitterbot|LinkedInBot|Slack|Discord|WhatsApp|KakaoTalk|Kakaostory|Line|Telegram|Pinterest|redditbot"
        }
      ],
      "destination": "/api/blog/[slug]"
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|favicon\\.svg|favicon\\.ico|manifest\\.json|naver.*\\.html|api\\/).*)",
      "destination": "/index.html"
    }
  ]
}
